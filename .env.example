SUPABASE_PROJECT_ID="your-project-id"
SUPABASE_PUBLISHABLE_KEY="your-anon-key"
SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Public site URL for SEO (canonical, Open Graph, sitemap) and OAuth redirects.
VITE_SITE_URL="https://herms.app"

# Firebase Cloud Messaging (push notifications)
# Create a project at https://console.firebase.google.com → Project settings → General (Web app)
# Cloud Messaging → Web Push certificates → copy key pair for VAPID_KEY below
# Android: download google-services.json → android/app/google-services.json
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_VAPID_KEY=""
VITE_FIREBASE_MEASUREMENT_ID=""
# Server-only: service account for sending push (use ONE of these)
# Local dev: path to gitignored JSON file
FIREBASE_SERVICE_ACCOUNT_PATH="firebase-service-account.json"
# Production (Vercel): paste minified JSON as a single line
FIREBASE_SERVICE_ACCOUNT_JSON=""

# Google Search Console (https://search.google.com/search-console)
# Meta tag method — paste content value only:
VITE_GOOGLE_SITE_VERIFICATION=""
# HTML file method — paste filename without path, e.g. google1234567890abcdef
VITE_GOOGLE_SITE_VERIFICATION_HTML=""

# Google OAuth — must match Supabase Site URL (same origin every sign-in)
VITE_AUTH_REDIRECT_ORIGIN="http://localhost:8081"

CAPACITOR_SERVER_URL="http://YOUR_LAN_IP:8080"

# OAuth redirect base (required on Android/tablet — WebView origin can be "null")
# PC browser: usually auto-detected; tablet: set to same URL as CAPACITOR_SERVER_URL
VITE_APP_URL="http://YOUR_LAN_IP:8080"
VITE_CAPACITOR_SERVER_URL="http://YOUR_LAN_IP:8080"

# Google OAuth — Google Cloud Console + Supabase Auth → Providers → Google
# Google redirect URI (Credentials → OAuth client → Web application):
#   https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
# Supabase Auth → URL Configuration → Redirect URLs:
#   http://localhost:8080/auth/callback
#   http://localhost:8081/auth/callback
#   http://localhost:5173/auth/callback
#   http://YOUR_LAN_IP:8080/auth/callback

# Razorpay Standard Checkout — https://dashboard.razorpay.com/app/keys
# Test: rzp_test_... (toggle Test Mode ON in dashboard — payments won't show in Live)
# Live: rzp_live_... (toggle Test Mode OFF — payments show under Transactions)
# Secret must NOT use VITE_ prefix (server-only)
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your_secret_key"

# Supabase service role — server-only, bypasses RLS for admin booking/payment writes
# Dashboard → Project Settings → API → service_role (secret)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
